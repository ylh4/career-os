# Secrets & environment
.env
.env.*
!.env.example

# Browser auth (cookies / saved login sessions captured by save_session.py) — never commit
.auth/

# Python
.venv/
__pycache__/
*.pyc

# Generated binary artifacts (keep the markdown sources, ignore exported docs)
# .docx/.pdf are render outputs of render_docx.py — regenerate them from the .md sources.
artifacts/*.docx
artifacts/**/*.docx
artifacts/**/*.pdf
sample-data/artifacts/**/*.docx
sample-data/artifacts/**/*.pdf

# Raw scraped postings (third-party content; kept locally for provenance/debugging)
pipeline/_raw/*
!pipeline/_raw/.gitkeep

# OS cruft
.DS_Store

# ── Private real corpus ──────────────────────────────────────────────────────
# sample-data/ (the fictitious candidate) IS committed so the repo runs on clone.
# If you keep your REAL corpus in this repo and do not want it version-controlled,
# separate it and uncomment the lines below. By default corpus/ is tracked so you
# can back it up; flip this if your fork is public.
# corpus/profile.md
# corpus/accomplishments/
# corpus/stories/
# pipeline/
